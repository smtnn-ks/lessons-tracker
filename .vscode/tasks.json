{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "prebuild",
            "dependsOn": [
                "build tailwind",
                "build templ"
            ],
        },
        {
            "label": "build tailwind",
            "type": "shell",
            "command": "bash -c 'cd ${workspaceFolder} && ./tailwind/tailwindcss -c ./tailwind/tailwind.config.js -i ./tailwind/input.css -o ./internal/app/static/css/style.css'",
            "presentation": {
                "close": true,
                "reveal": "always",
            }
        },
        {
            "label": "build templ",
            "type": "shell",
            "command": "go tool templ generate",
            "presentation": {
                "close": true,
                "reveal": "always",
            }
        }
    ]
}